# Expo App Environment Variables
# คัดลอกไฟล์นี้เป็น .env และกรอกค่าที่ถูกต้อง

# API Configuration - ชี้ไปที่ Backend API
API_VERSION=v1

# สำหรับ Production หรือ Development Server อื่นๆ
PROD_API_BASE_URL=https://your-production-api-url.com
DEV_API_BASE_URL=http://127.0.0.1:5000

# Authentication - ใช้ร่วมกับ Backend
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d

# External Services - Cloudinary สำหรับ Upload ไฟล์
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App Configuration
APP_ENV=development
APP_NAME=SiengPuenBan
APP_VERSION=1.0.0

# Debug Mode
DEBUG=true

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Push Notifications (สำหรับ Expo Notifications)
EXPO_PROJECT_ID=your-expo-project-id

# Social Authentication (ถ้าต้องการ)
GOOGLE_CLIENT_ID=your-google-client-id
FACEBOOK_APP_ID=your-facebook-app-id

{
  "expo": {
    "name": "SiengPuenBan",
    "slug": "sieng-puen-ban",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "7c6d8598-fa21-4f26-ab88-eb019a0d52b7"
      },
      "APP_ENV": "development",
      "DEBUG": true
    },
    "ios": {
      "bundleIdentifier": "com.nutkung2015.myapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  }
}

{
  "expo": {
    "name": "LIVLINK",
    "slug": "my-app",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "7c6d8598-fa21-4f26-ab88-eb019a0d52b7"
      },
      "APP_ENV": "production",
      "DEBUG": false,
      "PROD_API_BASE_URL": "https://snp68-spb.onrender.com",
      "DEV_API_BASE_URL": "http://127.0.0.1:5000",
      "API_VERSION": "v1"
    },
    "ios": {
      "bundleIdentifier": "com.nutkung2015.myapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nutkung2015.livlink",
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "orientation": "portrait",
    "icon": "./assets/livlink_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/livlink_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  }
}
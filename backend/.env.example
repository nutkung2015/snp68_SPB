# ===========================================
# Environment Variables Example
# Copy this file to .env.local (for development) or .env.production (for production)
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=sieng_puen_ban_1

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===========================================
# Security: Helmet Configuration
# ===========================================

# CORS: Allowed Origins (comma-separated)
# Development: http://localhost:8081,http://localhost:4200,http://127.0.0.1:5000
# Production: https://your-app.com,https://www.your-app.com
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:4200,http://127.0.0.1:5000

# CSP Frame Ancestors: Domains that can embed this backend (iframe)
# Development: http://localhost:8081,http://127.0.0.1:8081
# Production: https://your-app.com
ALLOWED_FRAME_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# ===========================================
# Production Only (uncomment when deploying)
# ===========================================
# NODE_ENV=production
# ALLOWED_ORIGINS=https://your-production-domain.com
# ALLOWED_FRAME_ORIGINS=https://your-production-domain.com
